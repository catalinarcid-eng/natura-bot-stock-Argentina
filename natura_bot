name: Natura Stock Bot

on:
  schedule:
    # Corre cada 3 horas (UTC)
    - cron: "0 */3 * * *"
  workflow_dispatch:
    # También permite correrlo manualmente desde GitHub

jobs:
  check-stock:
    runs-on: ubuntu-latest
    timeout-minutes: 30

    steps:
      # 1. Checkout del repositorio
      - name: Checkout código
        uses: actions/checkout@v4

      # 2. Python
      - name: Configurar Python 3.11
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      # 3. Dependencias Python
      - name: Instalar dependencias Python
        run: pip install -r requirements.txt

      # 4. Playwright (solo Chromium para ahorrar espacio)
      - name: Instalar Chromium (Playwright)
        run: python -m playwright install --with-deps chromium

      # 5. Restaurar memoria desde cache (persiste entre runs)
      - name: Restaurar memoria de productos notificados
        uses: actions/cache@v4
        with:
          path: memoria.json
          key: natura-memoria-${{ github.run_id }}
          restore-keys: |
            natura-memoria-

      # 6. Ejecutar bot
      - name: Ejecutar bot
        run: python natura_bot.py

      # 7. Guardar memoria actualizada (siempre, incluso si hay error)
      - name: Guardar memoria actualizada
        if: always()
        uses: actions/cache/save@v4
        with:
          path: memoria.json
          key: natura-memoria-${{ github.run_id }}
